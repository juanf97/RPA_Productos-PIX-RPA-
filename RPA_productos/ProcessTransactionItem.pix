            <_expression i:nil="true" />
            <_screenShotBase64 i:nil="true" />
            <_value xmlns:d7p1="http://www.w3.org/2001/XMLSchema" i:type="d7p1:string">using System.Data;
using System.Data.SqlClient;

using (var conn = new SqlConnection(cadenaConexion))
{
    conn.Open();

    var cmd = new SqlCommand(
        "SELECT category, AVG(price) FROM Productos GROUP BY category", conn);

    var adapter = new SqlDataAdapter(cmd);
    adapter.Fill(tablaPromedioCategoria);
}</_value>
