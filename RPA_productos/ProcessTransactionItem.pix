              </PropertyValue>
              <PropertyValue z:Id="i66">
                <PropertyName>SqlQuery</PropertyName>
                <_dataType>Expression</_dataType>
                <_expression>"IF NOT EXISTS (SELECT 1 FROM Productos WHERE id = " + id + ") " +
"INSERT INTO Productos (id, title, price, category, description) VALUES (" +
