            <PropertyValues>
              <PropertyValue z:Id="i62">
                <PropertyName>CSCode</PropertyName>
                <_dataType>Value</_dataType>
                <_expression i:nil="true" />
                <_screenShotBase64 i:nil="true" />
                <_value xmlns:d9p1="http://www.w3.org/2001/XMLSchema" i:type="d9p1:string">using System.Text.Json;

var doc = JsonDocument.Parse(respuestaAPI);
var productos = doc.RootElement;

if (i &gt;= productos.GetArrayLength()) return;

var producto = productos[i];


id = producto.GetProperty("id").ToString();
title = producto.GetProperty("title").ToString().Replace("'", "''");
price = producto.GetProperty("price").ToString();
category = producto.GetProperty("category").ToString().Replace("'", "''");
description = producto.GetProperty("description").ToString().Replace("'", "''");</_value>
                <_xpathSettings xmlns:d9p1="http://schemas.datacontract.org/2004/07/BR.XPath" i:nil="true" />
              </PropertyValue>
            </PropertyValues>
